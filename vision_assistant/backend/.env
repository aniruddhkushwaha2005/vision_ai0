# ── Vision Assistant — Environment Configuration ──────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALLOWED_ORIGINS=["https://your-frontend-domain.com"]

# ── Device / Inference ────────────────────────────────────────────────────────
MIDAS_DEVICE=cpu                  # cuda | cpu | mps
MIDAS_MODEL_TYPE=MiDaS_small      # MiDaS_small | DPT_Large
YOLO_MODEL_PATH=models/yolov8n.pt

# ── Navigation tuning ─────────────────────────────────────────────────────────
NAV_CENTER_BLOCK_THRESH=0.45      # raise to require objects closer before blocking
NAV_SMOOTHING_WINDOW=5            # increase for smoother but slower decisions
NAV_DANGER_DEPTH_THRESH=0.70

# ── TTS ───────────────────────────────────────────────────────────────────────
TTS_ENGINE=gtts                   # gtts | pyttsx3 | azure
TTS_HINDI_ENABLED=true
TTS_RATE_LIMIT_SECS=2.0

# ── Azure TTS (optional — highest quality) ────────────────────────────────────
# AZURE_TTS_KEY=your-azure-key
# AZURE_TTS_REGION=eastus

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                   # json (prod) | text (dev)

# ── Sentry (optional) ────────────────────────────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
