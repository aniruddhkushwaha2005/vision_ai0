{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI: Run Backend",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload",
                "--port",
                "8000"
            ],
            "jinja": true,
            "cwd": "${workspaceFolder}/backend",
            "justMyCode": true
        },
        {
            "name": "React Native: Run Android",
            "type": "react-native",
            "request": "launch",
            "platform": "android",
            "cwd": "${workspaceFolder}/frontend"
        },
        {
            "name": "React Native: Run iOS",
            "type": "react-native",
            "request": "launch",
            "platform": "ios",
            "cwd": "${workspaceFolder}/frontend"
        }
    ]
}
