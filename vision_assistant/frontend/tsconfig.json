{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["react", "react-native", "jest"]
  },
  "include": ["App.tsx", "global.d.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "ios/Pods"]
}
